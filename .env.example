# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tg_mini_shop?schema=public"

# Telegram bot token from @BotFather (used to validate initData and send messages).
TELEGRAM_BOT_TOKEN=""

# Numeric chat id of the admin (or admin group) that should receive order notifications.
ADMIN_CHAT_ID=""

# Password used to log in to /admin.
ADMIN_PASSWORD="change-me"

# Long random string used to sign the admin session cookie (>= 32 chars).
ADMIN_SESSION_SECRET="please-change-me-to-a-long-random-string"

# Optional: when set to "1", the backend skips Telegram initData HMAC validation.
# Only use locally, never in production.
SKIP_TELEGRAM_VALIDATION="0"
